# Agent Memory System Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Gemini API (Required for RAG semantic search)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Supabase (Required for vector database)
# Get from: https://app.supabase.io/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# OpenClaw (Optional, for multi-agent)
OPENCLAW_BASE_URL=http://localhost:18789
OPENCLAW_API_KEY=your_openclaw_key_here

# ============================================
# Feishu/Lark (Optional, for notifications)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ============================================
# Agent Configuration
AGENT_ID=claude_local
AGENT_NAME=Claude Local
USER_ID=your_user_id

# ============================================
# Memory System Paths (Optional, defaults to ~/agent-memory)
# AGENT_MEMORY_PATH=/path/to/agent-memory

# ============================================
# Loading Behavior (Optional)
# MEMORY_LOADER_MAX_P0=10
# MEMORY_LOADER_MAX_P1=20
# MEMORY_LOADER_MAX_DEPTH=2
